<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Mikrofon-Zugriff -->
    <key>NSMicrophoneUsageDescription</key>
    <string>Zum Aufnehmen von Sprachmemos auf der Baustelle</string>

    <!-- URL-Scheme für OIDC-Callback -->
    <key>CFBundleURLTypes</key>
    <array>
        <dict>
            <key>CFBundleURLName</key>
            <string>com.whisper-memo.oauth</string>
            <key>CFBundleURLSchemes</key>
            <array>
                <string>whispermemo</string>
            </array>
        </dict>
    </array>

    <!-- Background Audio (optional – erlaubt Aufnahme mit gesperrtem Screen) -->
    <key>UIBackgroundModes</key>
    <array>
        <string>audio</string>
    </array>
</dict>
</plist>
